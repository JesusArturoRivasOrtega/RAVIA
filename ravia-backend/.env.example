# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
# Android usa app/google-services.json.
# El backend necesita una llave de cuenta de servicio de Firebase Admin.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Alternativa para hosting: pegar el JSON completo en una variable de entorno.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# JWT fallback/session tokens if needed
JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_EXPIRATION=7d

# AI Analysis
# Leave as internal to use built-in keyword analysis.
AI_PROVIDER=internal
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Chatbot LLM provider
# If GROQ_API_KEY is present, chatbot/message uses Groq and falls back to local rules on error.
# GROQ_API_KEY=gsk-...
GROQ_MODEL=llama-3.3-70b-versatile

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
