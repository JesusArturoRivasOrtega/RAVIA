rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "ADMIN"];
    }

    function isModerator() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["moderator", "MODERATOR", "admin", "ADMIN"];
    }

    function isReportOwner() {
      return signedIn()
        && (resource.data.authorId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    function isIncomingReportOwner() {
      return signedIn()
        && (request.resource.data.authorId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if signedIn();
      allow create: if isIncomingReportOwner();
      allow update: if isModerator()
        || (isReportOwner()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "title", "description", "address", "media", "updatedAt"
          ]));
      allow delete: if isAdmin();
    }

    match /report_confirmations/{confirmationId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if signedIn();
      allow create, update: if isModerator();
      allow delete: if isAdmin();
    }

    match /risk_zones/{zoneId} {
      allow read: if signedIn();
      allow create, update: if isModerator();
      allow delete: if isAdmin();
    }

    match /missing_persons/{personId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isModerator()
        || (signedIn()
          && (resource.data.createdBy == request.auth.uid || resource.data.reportedBy == request.auth.uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "name", "age", "photoUrl", "lastSeenLocation", "lastSeenLatitude",
            "lastSeenLongitude", "clothing", "distinctiveSigns", "description",
            "contactInfo", "updatedAt"
          ]));
      allow delete: if isAdmin();
    }

    match /missing_person_sightings/{sightingId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /chatbot_messages/{messageId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }
  }
}
